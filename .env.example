# OffplanIQ — Environment Variables
# Copy to .env.local and fill in all values before running locally
# NEVER commit .env.local to git

# ─────────────────────────────────────────────
# SUPABASE
# Get these from: supabase.com → your project → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────
# STRIPE
# Get these from: dashboard.stripe.com → Developers → API keys
# Use TEST keys locally (sk_test_...), LIVE keys in production
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --forward-to localhost:3000/api/webhooks/stripe

# Price IDs — create these in Stripe Dashboard → Products
# Investor plan: AED 750/month (~$204 USD at time of writing)
STRIPE_PRICE_ID_INVESTOR=price_...
# Agency plan: AED 3500/month (~$953 USD)
STRIPE_PRICE_ID_AGENCY=price_...

# ─────────────────────────────────────────────
# RESEND (email)
# Get from: resend.com → API Keys
# Add and verify your sending domain (offplaniq.com)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─────────────────────────────────────────────
# SCRAPER (Python service)
# These go in Railway environment vars, not .env.local
# Listed here for documentation only
# ─────────────────────────────────────────────
# SUPABASE_URL=           (same as above)
# SUPABASE_SERVICE_KEY=   (same as SUPABASE_SERVICE_ROLE_KEY above)
# SCRAPER_SCHEDULE=       0 2 * * *   (2am UTC = 6am UAE daily)
# PF_SCRAPER_SCHEDULE=    0 */6 * * * (every 6h)

# ─────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=OffplanIQ

# Feature flags
NEXT_PUBLIC_SHOW_AGENCY_PLAN=true
NEXT_PUBLIC_MAINTENANCE_MODE=false
